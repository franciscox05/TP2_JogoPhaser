not** invent changes beyond what the diff describes."),e.hasAddedNode&&t.paragraph("**Added elements.** For new elements, use the **Reference** JSON as a guide for structure and props. Use existing components and patterns from the codebase where possible. **Asset images** may be attached\u2014one per image ref, keyed by the hash in **Image ref(s)**. For each image, **import** it (e.g. `import myImage from 'figma:asset/<hash>.png'`) and use the **imported variable** in `src={myImage}`. Do **not** put the `figma:asset/...` URL directly in `src=\"...\"`."),(e.hasAddedNode||e.hasRemovedNode)&&t.paragraph("**Preserve rendering patterns.** If elements in the target area are rendered from data (e.g. `.map()` over an array, loops), modify the data source or rendering logic rather than replacing it with hardcoded elements. When the diff shows multiple individual elements added or removed at the same source location, the intent is usually to change the underlying data or filter\u2014not to rewrite the rendering into static markup.")}(E,A,t),function(e,t,a,r){for(let T of u){let u=a.get(T);if(u?.length)for(let a of(t.h2(c[T]),u)){var i,l,d,f,k,I,M,E;let u=a[0];if(u)if(1===a.length)switch(T){case n.Y7.Color:i=e,l=t,d=u,f=r,d.targetKind!==n.$6.Prop?console.warn("Color change target kind is not prop",d):(l.h3(p(i,(0,o.rc)(d),d,f)),v(l,d));break;case n.Y7.Content:g(e,t,u,r);break;case n.Y7.Layout:m(e,t,u,r);break;case n.Y7.Typography:k=e,I=t,M=u,E=r,M.targetKind!==n.$6.Prop?console.warn("Typography change target kind is not prop",M):(I.h3(p(k,(0,o.b8)(M.propName),M,E)),v(I,M));break;default:!function(e,t,a,r){let s,o=S(a),i=C(a),l=w(a),d=e.changePrefix();if(a.op===n.vZ.Removed){let e=l??i;d+=`${o} removed${e?` (was \`${e}\`)`:""}`}else a.op===n.vZ.Modified&&void 0!==l&&void 0!==i?d+=`${o}: \`${l}\` \u{2192} \`${i}\``:a.op===n.vZ.Added&&void 0!==i?d+=`${o} set to \`${i}\``:a.op===n.vZ.Moved&&void 0!==a.oldPosition&&void 0!==a.newPosition?(d+=`${o} moved (position \`${a.oldPosition}