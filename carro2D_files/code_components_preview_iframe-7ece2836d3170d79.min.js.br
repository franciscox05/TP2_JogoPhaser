${n?`
/* Override pointer-events to ensure elementsFromPoint can detect them. */
body *:not(.fg-inspector-overlay):not(.fg-inspector-highlight):not(.fg-inspector-reorder-insert-marker):not(.fg-inspector-reorder-drop-parent-outline):not(.fg-inspector-reorder-drag-shell):not(.fg-inspector-reorder-placeholder):not([data-inspector-control]) {
  pointer-events: auto !important;
}
`:""}
:root {
  --fg-inspector-highlight-box-shadow: rgba(12, 140, 233, 0.5);
  --fg-inspector-highlight-background: rgba(12, 140, 233, 0.1);
  --fg-inspector-highlight-border-color: #0D99FF;
  --fg-inspector-highlight-component-border-color: #9747ff; /* ramp-purple-500-light */
  --fg-inspector-tag-label-color: rgba(255, 255, 255, 1);
}
.fg-inspector-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999999;
  user-select: none !important;
  -webkit-user-select: none !important;
}
.fg-inspector-black-cursor {
  cursor:url("data:image/png;base64,")4 4,auto !important;
}
.fg-inspector-comment-cursor {
  cursor:url("data:image/svg+xml;base64,")4 24,auto !important;
}
.fg-inspector-reorder-dragging {
  pointer-events: none;
}
/* Translucent rectangle that follows the cursor during a reorder drag. Hosts paint this
   with width/height and an inline transform: translate3d(...) taken from the snapshot. */
.fg-inspector-reorder-drag-shell {
  position: fixed;
  top: 0;
  left: 0;
  transform: translate3d(0, 0, 0);
  pointer-events: none;
  z-index: 10000003;
  background: rgba(151, 71, 255, 0.28); /* ramp-purple-500-light @ ~28% */
  border: 1px solid var(--fg-inspector-highlight-component-border-color);
  box-sizing: border-box;
  border-radius: 2px;
}
/* In-flow slot geometry for the dragged element \u{2014} no fill/border (layout slot only). */
.fg-inspector-reorder-placeholder {
  position: fixed;
  top: 0;
  left: 0;
  transform: translate3d(0, 0, 0);
  pointer-events: none;
  z-index: 10000002;
  background: transparent;
  border: none;
  box-shadow: none;
  box-sizing: border-box;
  border-radius: 2px;
}
/* Destination parent while reordering */
.fg-inspector-reorder-drop-parent-outline {
  position: fixed;
  top: 0;
  left: 0;
  transform: translate3d(0, 0, 0);
  pointer-events: none;
  z-index: 10000003;
  box-sizing: border-box;
  border-radius: 2px;
  outline: 1px dashed var(--fg-inspector-highlight-border-color);
  outline-offset: 0;
}
/* HtmlEditor reorder insertion bar */
.fg-inspector-reorder-insert-marker {
  position: fixed;
  pointer-events: none;
  z-index: 10000004;
  background: var(--fg-inspector-highlight-border-color);
  border-radius: 2px;
  box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.35);
  /* width/height set inline from reorder geometry */
}
.fg-inspector-reorder-insert-marker.fg-inspector-reorder-insert-marker-rest-slot {
  opacity: 1;
  background: color-mix(in srgb, var(--fg-inspector-highlight-border-color) 22%, transparent);
  box-shadow: 0 0 0 1px color-mix(in srgb, var(--fg-inspector-highlight-border-color) 55%, transparent);
  border-radius: 2px;
}
.fg-inspector-drag-select-rect {
  border: 2px dashed color-mix(in srgb, var(--fg-inspector-highlight-border-color) 60%, transparent);
  background: color-mix(in srgb, var(--fg-inspector-highlight-border-color) 8%, transparent);
  pointer-events: none;
  z-index: var(--fg-inspector-drag-select-rect-z-index, 10000001);
}
.fg-inspector-highlight {
  position: fixed;
  top: 0;
  left: 0;
  transform: translate3d(0, 0, 0);
  pointer-events: none;
  z-index: 9999998;
  /* Default: 1px border for all states */
  box-shadow: 0 0 0 1px var(--fg-inspector-highlight-border-color);
}

/* Library components use purple border */
.fg-inspector-highlight.fg-inspector-highlight-component {
  box-shadow: 0 0 0 1px var(--fg-inspector-highlight-component-border-color);
}

/* Hovered direct: 2px border (takes visual precedence over selected) */
.fg-inspector-highlight-hovered {
  box-shadow: 0 0 0 2px var(--fg-inspector-highlight-border-color);
}
.fg-inspector-highlight-hovered.fg-inspector-highlight-component {
  box-shadow: 0 0 0 2px var(--fg-inspector-highlight-component-border-color);
}

/* Textedit: 1px border, takes precedence over hovered to allow text editing */
.fg-inspector-highlight-textedit {
  box-shadow: 0 0 0 1px var(--fg-inspector-highlight-border-color);
}
.fg-inspector-highlight-textedit.fg-inspector-highlight-component {
  box-shadow: 0 0 0 1px var(--fg-inspector-highlight-component-border-color);
}

/* Drag-select preview is a highlight modifier and should override base highlight styles. */
.fg-inspector-drag-select-preview {
  box-shadow: 0 0 0 1px var(--fg-inspector-highlight-border-color);
  background: rgba(12, 140, 233, 0.12);
}

/* Sweeping gradient signaling that the element's edits are in flight to the
 * agent. Mirrors the slides AI shimmer pattern (web/js/slides/ai/...): the
 * 600% background-size makes the bright zone a narrow slice through the
 * element regardless of element width. */
.fg-inspector-highlight-applying {
  box-shadow: none;
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.2);
  overflow: hidden;
  isolation: isolate;
}
.fg-inspector-highlight-applying::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    -45deg,
    rgba(255, 255, 255, 0),
    rgba(255, 255, 255, 0) 30%,
    rgba(255, 255, 255, 0.75) 50%,
    rgba(255, 255, 255, 0) 70%
  );
  background-size: 600%;
  background-position-x: 100%;
  animation: fg-inspector-shimmer-sweep 2s linear infinite;
  pointer-events: none;
}
@keyframes fg-inspector-shimmer-sweep {
  to {
    background-position-x: 0%;
  }
}
.fg-inspector-tag-label {
  position: fixed;
  top: -31px;
  left: -1px;
  max-width: 150px;
  height: 24px;
  line-height: 24px !important;
  display: inline-flex;
  align-items: center;
  gap: 2px;
  overflow: hidden;
  color: var(--fg-inspector-tag-label-color) !important;
  padding: 0.5px 6px;
  font-size: 11px !important;
  font-family: 'Inter', sans-serif !important;
  font-weight: 450 !important;
  border-radius: 5px;
  white-space: nowrap !important;
  pointer-events: none;
  z-index: 9999999;
}
.fg-inspector-tag-label-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}
.fg-inspector-tag-label-drag-handle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 16px;
  width: 16px;
  height: 16px;
  margin-left: -2px;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  cursor: grab;
  pointer-events: auto;
  --fpl-icon-color-2: currentColor;
}
.fg-inspector-tag-label-drag-handle:active {
  cursor: grabbing;
}
.fg-inspector-tag-label-drag-handle svg {
  display: block;
  width: 16px;
  height: 16px;
}
body.fg-inspector-reorder-grabbing,
body.fg-inspector-reorder-grabbing * {
  cursor: grabbing !important;
}
.fg-inspector-tag-label-selected {
  background-color: var(--fg-inspector-highlight-border-color);
  /* Offset to compensate for selected highlight having 1px padding adjustment */
  top: -30px;
  left: 0px;
}
.fg-inspector-tag-label-below {
  /* Vertical offset is set inline from the adjusted highlight height. */
  left: -1px;
}
.fg-inspector-tag-label-below.fg-inspector-tag-label-selected {
  left: 0px;
}
.fg-inspector-tag-label-inset {
  top: 2px;
  left: 2px;
}
.fg-inspector-tag-label-inset.fg-inspector-tag-label-selected {
  top: 3px;
  left: 3px;
}
.fg-inspector-tag-label-hovered {
  background-color: var(--fg-inspector-highlight-border-color);
}
.fg-inspector-tag-label-component {
  background-color: var(--fg-inspector-highlight-component-border-color);
}
/* [Right Panel Properties Experiment] DRI: @ehu-figma \u{2014} padding/margin rings
   shown while the user is hovering/focusing a spacing input in the right panel. */
.fg-inspector-spacing-highlight {
  position: fixed;
  top: 0;
  left: 0;
  transform: translate3d(0, 0, 0);
  pointer-events: none;
  box-sizing: border-box;
  /* Just below .fg-inspector-overlay (9999999) so selection highlights still win. */
  z-index: 9999997;
}
.fg-inspector-spacing-highlight-padding {
  background-color: rgba(147, 196, 125, 0.55);
}
.fg-inspector-spacing-highlight-margin {
  background-color: rgba(246, 178, 107, 0.55);
}
.fg-inspector-spacing-highlight-gap {
  background-color: rgba(180, 134, 255, 0.55);
}
.fg-inspector-annotation-marker {
  /* Layering contract: markers are page-side geometry, so they sit in the
     fg-inspector overlay family for screenshot exclusion. They render above
     regular PAE highlights (9999999), comments-mode cursor affordances, and
     reorder drag shells (10000003), while editor-side React owns only the input
     popup above the preview surface. */
  position: fixed;
  top: 0;
  left: 0;
  width: 24px;
  height: 24px;
  padding: 0;
  border: 1px solid var(--fg-annotation-marker-border, rgba(0, 0, 0, 0.2));
  border-radius: 50%;
  background: var(--fg-annotation-marker-background, #0D99FF);
  color: var(--fg-annotation-marker-color, #ffffff);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.22);
  font-family: 'Inter', sans-serif !important;
  font-size: 11px !important;
  font-weight: 600 !important;
  line-height: 22px !important;
  text-align: center;
  cursor: pointer !important;
  pointer-events: auto;
  user-select: none;
  z-index: 10000005;
  transform-origin: center;
  transform: scale(1);
  transition-property: transform, box-shadow;
  transition-duration: 150ms;
  transition-timing-function: ease-out;
}
.fg-inspector-annotation-marker-hovered,
.fg-inspector-annotation-marker:hover {
  transform: scale(1.15) !important;
  box-shadow: 0 3px 12px rgba(0, 0, 0, 0.45);
}
.fg-inspector-bold {
  font-weight: bold;
}
.fg-inspector-italic {
  font-style: italic;
}
[data-fginspector-texteditor-ready] + * {
  display: none !important;
}
[data-fginspector-texteditor-hidden] {
  display: none !important;
}
[data-fginspector-selected],
[data-fginspector-selected] *,
[data-fginspector-selected]:active,
[data-fginspector-selected]:focus,
[data-fginspector-selected]:focus-visible,
[data-fginspector-selected]:focus-within,
[data-fginspector-selected]:hover {
  outline: none !important;
}
/* Editor and selector mode: also suppress transitions and scale on selected elements
   to prevent hover/focus effects from interfering with selection/editing.
   Comments mode omits this so dom-snapshot captures the correct visual state. */
body:is([data-fginspector-mode="editor"], [data-fginspector-mode="selector"]) [data-fginspector-selected],
body:is([data-fginspector-mode="editor"], [data-fginspector-mode="selector"]) [data-fginspector-selected] *,
body:is([data-fginspector-mode="editor"], [data-fginspector-mode="selector"]) [data-fginspector-selected]:active,
body:is([data-fginspector-mode="editor"], [data-fginspector-mode="selector"]) [data-fginspector-selected]:focus,
body:is([data-fginspector-mode="editor"], [data-fginspector-mode="selector"]) [data-fginspector-selected]:focus-visible,
body:is([data-fginspector-mode="editor"], [data-fginspector-mode="selector"]) [data-fginspector-selected]:focus-within,
body:is([data-fginspector-mode="editor"], [data-fginspector-mode="selector"]) [data-fginspector-selected]:hover {
  scale: revert !important;
  transition: none !important;
}
[data-fginspector-texteditor],
[data-fginspector-texteditor] *,
[data-fginspector-texteditor]:active,
[data-fginspector-texteditor]:focus,
[data-fginspector-texteditor]:focus-visible,
[data-fginspector-texteditor]:focus-within,
[data-fginspector-texteditor]:hover {
  outline: none !important;
  scale: revert !important;
  transition: none !important;
}
[data-fginspector-texteditor],
[data-fginspector-texteditor] * {
  cursor: text !important;
}
