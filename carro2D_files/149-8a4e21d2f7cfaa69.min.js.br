      fill="#155dfc"
      cornerRadius={6}
      flex="vertical"
      spacing={10}
      verticalAlignItems="center"
      horizontalAlignItems="center"
      width={200}
      height={200}
    >
      <Span fill="#FFFFFF">{text}</Span>
    </Frame>
  );
}

