    confetti({
      particleCount: 100,
      spread: 70,
      origin: { y: 0.6 }
    });
  };

  return (
    <div className="flex flex-wrap items-center justify-center size-full p-2 gap-1 bg-white">
      <Button
        variant="outline"
        className="make-hello-button text-md font-medium text-muted-foreground hover:bg-black hover:text-white border-transparent"
        onClick={handleClick}
      >
        <span className="wave-shake inline-block">\u{1F44B}</span>
        Hello, Make!
      </Button>
    </div>
  );
